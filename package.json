{
  "name": "agenda-academica",
  "version": "0.1.0",
  "private": true,
  "description": "Agenda Academica Digital Unificada - monorepo com backend AdonisJS e frontend Next.js.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspaces --if-present run build",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint",
    "format": "npm --workspaces --if-present run format"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "allowScripts": {
    "better-sqlite3@12.10.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
